{
    "name": "@sendlix/nodemailer",
    "root": "packages/nodemailer",
    "sourceRoot": "packages/nodemailer/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "dependsOn": [
                "^build"
            ],
            "options": {
                "command": "npm --prefix packages/nodemailer run build"
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "dependsOn": [
                "^build"
            ],
            "options": {
                "command": "npm --prefix packages/nodemailer run test"
            }
        }
    }
}