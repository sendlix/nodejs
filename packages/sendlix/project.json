{
    "name": "sendlix",
    "root": "packages/sendlix",
    "sourceRoot": "packages/sendlix/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": [
                "packages/sendlix/dist/**"
            ],
            "options": {
                "command": "npm --prefix packages/sendlix run build"
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npm --prefix packages/sendlix run test"
            }
        }
    }
}